# ---------------------------------------------------------------
# FranchiseHub — environment variables
# Copy to .env.local and fill in. NEVER commit .env or .env.local.
# ---------------------------------------------------------------

# --- Supabase (required) ---
# Project: egucihmwendiaaoskpno
# Dashboard: https://supabase.com/dashboard/project/egucihmwendiaaoskpno
NEXT_PUBLIC_SUPABASE_URL=https://egucihmwendiaaoskpno.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# SERVICE_ROLE_KEY must NEVER appear in a NEXT_PUBLIC_* variable.
# It belongs in Edge Functions / server-only code only.
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Email (Resend — required for transactional emails) ---
# https://resend.com/api-keys
# RESEND_API_KEY=your_resend_api_key_here
# RESEND_FROM_EMAIL=noreply@franchisehub.ph

# --- Error monitoring (Sentry — optional, recommended) ---
# https://sentry.io/settings/<org>/projects/<project>/keys/
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- App configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FranchiseHub
